# Database
DATABASE_URL=postgresql+asyncpg://refarm:refarm_password@localhost:5432/refarm_eos

# Security
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
CORS_ORIGINS=https://app.refarmkobe.com,https://refarm-nine.vercel.app,https://refarm-production.up.railway.app
CORS_LOCAL_ORIGINS=http://localhost:5173,http://localhost:3000

# LINE LIFF
LIFF_ID=your-liff-id-here
LINE_CHANNEL_SECRET=your-channel-secret-here
LINE_RESTAURANT_CHANNEL_ID=
LINE_RESTAURANT_CHANNEL_SECRET=
LINE_RESTAURANT_CHANNEL_ACCESS_TOKEN=
LINE_PRODUCER_CHANNEL_ID=
LINE_PRODUCER_CHANNEL_SECRET=
LINE_PRODUCER_CHANNEL_ACCESS_TOKEN=
LINE_CONSUMER_CHANNEL_ID=
LINE_CONSUMER_CHANNEL_SECRET=
LINE_CONSUMER_ACCESS_TOKEN=

# LINE Messaging API (Admin)
LINE_ADMIN_CHANNEL_ID=
LINE_ADMIN_CHANNEL_SECRET=
LINE_ADMIN_CHANNEL_ACCESS_TOKEN=
LINE_ADMIN_USER_IDS=

# Application
APP_NAME=Refarm EOS
APP_VERSION=3.0.0
DEBUG=False

# Timezone
TZ=Asia/Tokyo

# Email (order notifications)
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=your-email@example.com
EMAIL_SMTP_PASSWORD=your-app-password
EMAIL_FROM=refarmkobe@gmail.com
EMAIL_TO=refarmkobe@gmail.com
EMAIL_USE_TLS=True
